    {
      "id": "jdiwgaff",
      "type": "visink/CustomProgram",
      "x": 337,
      "y": 269,
      "inputs": [
        {
          "id": "chargingId",
          "label": "充电桩id"
        }
      ],
      "outputs": [
        {
          "id": "status",
          "label": "状态"
        },
        {
          "id": "duration",
          "label": "时长"
        },
        {
          "id": "kwh",
          "label": "充电度数"
        },
        {
          "id": "userId",
          "label": "用户id"
        },
        {
          "id": "fee",
          "label": "费用"
        }
      ],
      "code": "let cachedStatus = null;\nlet startTime = null;\nlet cachedUserId = null;\n\nreturn (chargingId) => {\n  if (cachedStatus === null) {\n    const statuses = ['idle', 'working', 'error'];\n    cachedStatus = statuses[Math.floor(Math.random() * statuses.length)];\n    \n    // 生成随机8位用户ID并持久缓存\n    cachedUserId = String(Math.floor(Math.random() * 90000000) + 10000000);\n    \n    if (cachedStatus === 'working') {\n      // 过去8小时内的一个随机时间点（时间戳）\n      const eightHoursMs = 8 * 60 * 60 * 1000;\n      startTime = Date.now() - Math.floor(Math.random() * eightHoursMs);\n    }\n  }\n  if (cachedStatus !== 'working') {\n    return {\n      status: cachedStatus\n    }\n  }\n  \n  let duration = null;\n  let kwh = null;\n  let fee = null;\n  \n  if (cachedStatus === 'working' && startTime !== null) {\n    const now = Date.now();\n    const diffMs = now - startTime;\n    const totalSeconds = Math.floor(diffMs / 1000);\n    const hours = Math.floor(totalSeconds / 3600);\n    const minutes = Math.floor((totalSeconds % 3600) / 60);\n    const seconds = totalSeconds % 60;\n    \n    duration = [\n      String(hours).padStart(2, '0'),\n      String(minutes).padStart(2, '0'),\n      String(seconds).padStart(2, '0')\n    ].join(':');\n    \n    const durationHours = diffMs / (1000 * 60 * 60);\n    kwh = parseFloat((durationHours * 0.82).toFixed(3));\n    fee = parseFloat((kwh * 0.82).toFixed(3));\n  }\n  \n  return {\n    status: cachedStatus,\n    duration: duration,\n    kwh: kwh + '度',\n    userId: cachedUserId,\n    fee: fee + '元'\n  };\n};"
    },
