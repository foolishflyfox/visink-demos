      "code": "let sum = 0;\nreturn (cmd) => {\n  if (!cmd || typeof cmd !== 'object') return {};\n  if (cmd.op === 'set') sum = Number(cmd.value);\n  else if (cmd.op === 'add') sum += Number(cmd.value);\n  return { text: sum.toFixed(3) };\n};\n"
    }
